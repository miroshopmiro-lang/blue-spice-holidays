# Long-cache all media assets (30 days) so hero videos/posters download once and loop for free.
# Matches Black Tomato's 31-day policy and replaces the prior 4-hour default that let warm caches
# age out during peak hours and re-download the whole hero on a cold buffer. Re-encoded hero clips
# are version-suffixed (-v2 / -v2-m), so a future re-encode gets a new filename and busts cleanly.
/images/*
  Cache-Control: public, max-age=2592000
/brochures/*
  Cache-Control: public, max-age=2592000

# /sw.js is now a one-time kill switch (vite.config.js: selfDestroying) that
# unregisters any service worker a past build left installed and clears its
# caches. It must stay no-cache so returning visitors fetch the real kill
# switch immediately rather than a stale cached copy of the old SW.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Entry HTML never cached so deploys are visible immediately.
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# One-off support page for diagnosing a specific device. Must never be cached —
# it exists to report the live state of whatever phone is opening it, and a
# stale copy would report a stale answer. noindex is set in the page itself.
/diag.html
  Cache-Control: no-cache, no-store, must-revalidate

# Manifests are tiny and change rarely, but a stale one is disproportionately
# annoying (wrong icons/theme colour pinned to a home-screen install), so keep
# them revalidating. /manifest.webmanifest is the orphaned vite-plugin-pwa
# artefact — _redirects points it at /site.webmanifest, and this stops the edge
# from holding any copy of that path long-term again.
/site.webmanifest
  Cache-Control: no-cache, must-revalidate
/manifest.webmanifest
  Cache-Control: no-cache, no-store, must-revalidate
